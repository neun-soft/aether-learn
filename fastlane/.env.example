# App Store Connect API key — copy this file to fastlane/.env and fill in.
# Create a key at: App Store Connect → Users and Access → Integrations → App Store Connect API
# Download the .p8 ONCE (Apple never shows it again) and store it outside git.

# The "Key ID" column next to your key
ASC_KEY_ID=XXXXXXXXXX

# The "Issuer ID" shown at the top of the Integrations page (a UUID)
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Absolute path to the downloaded AuthKey_XXXXXXXXXX.p8 file (keep it out of the repo)
ASC_KEY_PATH=/Users/diego/.appstoreconnect/AuthKey_XXXXXXXXXX.p8

# Set to 1 to skip the clean-git-tree check and release tagging (useful for dry runs)
# SKIP_GIT_CHECK=1

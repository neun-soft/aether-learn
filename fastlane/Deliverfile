# Defaults for upload_to_app_store (deliver). Auth comes from the API key set
# in the Fastfile, so no apple_id is needed here.

# Skip binary upload in the metadata-only path; the release lane builds + uploads
# the ipa itself, so deliver should only push metadata/screenshots.
force(true)                       # no HTML preview prompt in CI
precheck_include_in_app_purchases(false)
submit_for_review(false)          # keep manual submission until content is final

# 6.7" screenshots live in fastlane/screenshots/en-US (Apple scales this set to
# the other iPhone sizes). Regenerate with: swift tool/make-screenshots.swift fastlane/screenshots/en-US
skip_screenshots(false)
